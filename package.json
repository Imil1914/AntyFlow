{
  "name": "flow",
  "version": "0.1.0",
  "description": "Локальный AI-холст (Figma + Miro + Docs + локальные модели)",
  "main": "./out/main/index.js",
  "author": "Flow",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "icon": "node scripts/gen-icon.mjs",
    "prepare-sidecars": "node scripts/prepare-sidecars.mjs",
    "build-anythingllm": "node scripts/build-anythingllm.mjs",
    "dist": "node scripts/prepare-sidecars.mjs && electron-vite build && electron-builder",
    "dist:dir": "node scripts/prepare-sidecars.mjs && electron-vite build && electron-builder --dir"
  },
  "build": {
    "appId": "com.flow.aicanvas",
    "productName": "Flow",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "sidecars/bin",
        "to": "bin"
      },
      {
        "from": "sidecars/node",
        "to": "node"
      },
      {
        "from": "sidecars/anythingllm",
        "to": "anythingllm"
      }
    ],
    "asarUnpack": [
      "node_modules/pdf-parse/**",
      "node_modules/pdfjs-dist/**",
      "node_modules/@napi-rs/**",
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**",
      "node_modules/node-gyp-build/**",
      "out/main/orchestratorWorker.js",
      "out/main/chunks/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Flow"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@huggingface/transformers": "^4.2.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tldraw/sync": "^3.15.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.47",
    "mermaid": "^11.16.0",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "react-markdown": "^9.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tldraw": "^3.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}